import 'package:flutter/material.dart';

class EcgCard extends StatelessWidget {

final String title;

final String image;

final VoidCallback onTap;

const EcgCard({

super.key,

required this.title,

required this.image,

required this.onTap,

});

@override

Widget build(BuildContext context){

return Card(

child: ListTile(

leading: Image.asset(image,width:60),

title: Text(title),

trailing: const Icon(Icons.arrow_forward_ios),

onTap:onTap,

),

);

}

}
class EcgScreen extends StatelessWidget {

const EcgScreen({super.key});

@override

Widget build(BuildContext context){

return Scaffold(

appBar: AppBar(

title: const Text("EKG Eğitim"),

),

body: ListView.builder(

itemCount: ecgList.length,

itemBuilder:(context,index){

final ecg=ecgList[index];

return EcgCard(

title: ecg.title,

image: ecg.image,

onTap:(){

Navigator.push(

context,

MaterialPageRoute(

builder:(_)=>EcgDetailScreen(ecg:ecg),

),

);

},

);

},

),

);

}

}
class EcgDetailScreen extends StatelessWidget {

final EcgModel ecg;

const EcgDetailScreen({

super.key,

required this.ecg,

});

@override

Widget build(BuildContext context){

return Scaffold(

appBar: AppBar(

title: Text(ecg.title),

),

body: SingleChildScrollView(

padding: const EdgeInsets.all(20),

child: Column(

crossAxisAlignment: CrossAxisAlignment.start,

children: [

Image.asset(ecg.image),

const SizedBox(height:20),

Text(

ecg.description,

style: const TextStyle(

fontSize:18,

fontWeight: FontWeight.bold,

),

),

const SizedBox(height:20),

...ecg.findings.map(

(item)=>ListTile(

leading: const Icon(Icons.check),

title: Text(item),

),

),

],

),

),

);

}

}
