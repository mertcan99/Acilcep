class CalculatorService {

  // Ortalama Arter BasДұncДұ (MAP)
  static double calculateMAP({
    required int systolic,
    required int diastolic,
  }) {
    return (systolic + 2 * diastolic) / 3;
  }

  // Glasgow Koma SkalasДұ
  static int calculateGCS({
    required int eye,
    required int verbal,
    required int motor,
  }) {
    return eye + verbal + motor;
  }

  // Pediatrik doz
  static double calculateDose({
    required double weightKg,
    required double mgPerKg,
    double? maxDose,
  }) {
    double dose = weightKg * mgPerKg;

    if (maxDose != null && dose > maxDose) {
      return maxDose;
    }

    return dose;
  }
}
